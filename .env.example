# ---------------------------------------------------------------------------
# ResearchCompass environment configuration
# Copy this file to `.env` and fill in the values you have available.
# The system is designed to run even with NONE of these set (using local
# embeddings + rule-based routing + offline placeholders), but functionality
# is progressively enhanced as you add keys.
# ---------------------------------------------------------------------------

# --- LLM (OpenAI). Leave blank to use rule-based / template fallbacks. ------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# --- Embeddings --------------------------------------------------------------
# "sentence_transformers" (default, local, no key needed) or "openai"
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Tavily web search (for trend queries) ------------------------------------
TAVILY_API_KEY=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

# --- Semantic Scholar (public API; key optional, raises rate limits) ---------
SEMANTIC_SCHOLAR_API_KEY=

# --- SMTP (for the email agent) -----------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=researchcompass@university.edu

# --- Behaviour -----------------------------------------------------------------
REQUIRE_CONFIRMATION=true
LOG_LEVEL=INFO
TOP_K_FACULTY=5
